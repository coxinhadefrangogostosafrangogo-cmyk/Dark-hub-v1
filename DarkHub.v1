end)

-- Atualizar lista periodicamente
coroutine.wrap(function()
    while task.wait(2) do
        updatePlayersList()
    end
end)()

-- Infinite Jump
UserInputService.JumpRequest:Connect(function()
    if infiniteJump and Humanoid then
        Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)

-- God Mode (proteção contínua)
coroutine.wrap(function()
    while task.wait(0.1) do
        if godMode and Character then
            local hum = Character:FindFirstChild("Humanoid")
            if hum and hum.Health < hum.MaxHealth then
                hum.Health = hum.MaxHealth
            end
        end
    end
end)()

-- Reconectar quando o personagem muda
Player.CharacterAdded:Connect(function(char)
    Character = char
    Humanoid = char:WaitForChild("Humanoid")
    RootPart = char:WaitForChild("HumanoidRootPart")
    
    if godMode and Humanoid then
        Humanoid.MaxHealth = 999999
        Humanoid.Health = 999999
    end
    
    if speedValue and Humanoid then
        Humanoid.WalkSpeed = speedValue
    end
    
    if antiKnockback and RootPart then
        RootPart.CustomPhysicalProperties = PhysicalProperties.new(9999, 0.3, 0.5)
    end
end)

-- Função de minimizar/maximizar
MinimizeButton.MouseButton1Click:Connect(function()
    menuMinimized = not menuMinimized
    if menuMinimized then
        MainFrame.Visible = false
        MinimizedBall.Visible = true
        -- Animação de surgimento da bolinha
        MinimizedBall.Size = UDim2.new(0, 0, 0, 0)
        TweenService:Create(MinimizedBall, TweenInfo.new(0.3, Enum.EasingStyle.Bounce), {Size = UDim2.new(0, 60, 0, 60)}):Play()
    else
        MainFrame.Visible = true
        MinimizedBall.Visible = false
    end
end)

-- Clique na bolinha para restaurar
MinimizedBall.MouseButton1Click:Connect(function()
    menuMinimized = false
    MinimizedBall.Visible = false
    MainFrame.Visible = true
    -- Animação de restauração
    MainFrame.Size = UDim2.new(0, 0, 0, 0)
    TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0, 420, 0, 420)}):Play()
end)

-- Tornar arrastável (MENU PRINCIPAL)
local draggingMain = false
local dragStart, startPos

MainFrame.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        draggingMain = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

-- Tornar arrastável (BOLINHA)
local draggingBall = false
local ballDragStart, ballStartPos

MinimizedBall.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        draggingBall = true
        ballDragStart = input.Position
        ballStartPos = MinimizedBall.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingMain and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    elseif draggingBall and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - ballDragStart
        MinimizedBall.Position = UDim2.new(ballStartPos.X.Scale, ballStartPos.X.Offset + delta.X, ballStartPos.Y.Scale, ballStartPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingMain = false
        draggingBall = false
    end
end)

-- Fechar GUI
CloseButton.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
end)

-- Mostrar primeira página por padrão
pages["ESP 👁️"].Visible = true
updatePlayersList()

print("Dark Hub v1.5 carregado com sucesso!")
print("Clique em − para minimizar o menu!")
print("A bolinha preta com >:3 é seu menu minimizado!")
