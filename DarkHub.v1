-- Efeito neon no título
coroutine.wrap(function()
    local hue = 0
    while ScreenGui and ScreenGui.Parent do
        hue = (hue + 0.005) % 1
        Title.TextColor3 = Color3.fromHSV(hue, 1, 1)
        RunService.Heartbeat:Wait()
    end
end)()

